{
  "name": "robot-performance-analyzer",
  "displayName": "Robot Performance Analyzer",
  "description": "Performance & Bottleneck Analyzer for Robot Framework",
  "version": "1.0.0",
  "publisher": "yourpublishername",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:robot",
    "onCommand:robotAnalyzer.analyzeFile",
    "onCommand:robotAnalyzer.openDashboard",
    "onCommand:robotAnalyzer.openOutput"
  ],
  "contributes": {
    "commands": [
      { "command": "robotAnalyzer.analyzeFile", "title": "Robot: Analyze Current File" },
      { "command": "robotAnalyzer.openDashboard", "title": "Robot: Open Performance Dashboard" },
      { "command": "robotAnalyzer.openOutput", "title": "Robot: Open Output Viewer" }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.5"
  }
}